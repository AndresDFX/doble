# Local (docker compose / dev):
DATABASE_URL=postgresql://wa_agent:wa_agent_dev@localhost:5432/wa_agent
# Render / nube — usa el Session Pooler de Supabase (IPv4 + prepared statements):
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# (Neon: postgresql://...neon.tech/db?sslmode=require). El gateway activa SSL solo si
# el string trae sslmode (ver gateway/src/db.ts). NO uses el puerto 6543 (transaction).

GEMINI_API_KEY=AIza...
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=1536

GATEWAY_PORT=3000
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000

# Resolved relative to the gateway/ folder if not absolute.
WA_SESSION_DIR=.wa-session
WA_MEDIA_DIR=.wa-media

# --- WhatsApp session store ---------------------------------------------------
# "files"  (default) → session on local disk (WA_SESSION_DIR). Local / compose.
# "dynamo"           → session in DynamoDB, for ephemeral-disk hosts (Render).
#                      Requires WA_AUTH_TABLE + AWS creds below.
WA_AUTH_STORE=files
WA_SESSION_ID=default
WA_AUTH_TABLE=doble-whatsapp-auth
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# --- Public hosting (Render) --------------------------------------------------
# Basic Auth over the admin API + dashboard. Leave ADMIN_PASSWORD blank locally
# (open); set it whenever the gateway is reachable on a public URL.
ADMIN_USER=admin
# ADMIN_PASSWORD=

# When set, the gateway serves the built SPA from this dir, same-origin as /api
# (used on Render). Leave unset locally — Vite/nginx serve the frontend there.
# FRONTEND_DIST=/app/frontend-dist

# Render injects PORT automatically; GATEWAY_PORT / AI_SERVICE_PORT win locally.

# Mensajes proactivos (el agente escribe primero, cadencia aleatoria por chat).
# La activación y el rango (min-max minutos) son POR CHAT (pestaña Chats / CLI);
# esto solo controla el loop global: si corre y cada cuánto revisa.
PROACTIVE_SCHEDULER=on
PROACTIVE_TICK_MS=30000
